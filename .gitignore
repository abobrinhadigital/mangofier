# .gitignore

# ----------------------------------------------------------------------
# AS CHAVES DO REINO (Nunca, jamais, em hipótese alguma suba isso)
# ----------------------------------------------------------------------
.env
.env.*
!.env.example

# ----------------------------------------------------------------------
# O BAÚ DO TESOURO (O nosso banco de dados da preguiça)
# ----------------------------------------------------------------------
db/*.sqlite3
db/*.sqlite3-journal
db/*.sqlite3-shm
db/*.sqlite3-wal
data/*

# ----------------------------------------------------------------------
# O LIXO DO RUBY (Coisas que o seu i3 não precisa compartilhar com o mundo)
# ----------------------------------------------------------------------
.bundle/
vendor/bundle/
*.gem
*.rbc
.ruby-version
.ruby-gemset

# ----------------------------------------------------------------------
# LOGS E FANTASMAS DO SISTEMA
# ----------------------------------------------------------------------
log/
*.log
tmp/
.DS_Store
Thumbs.db

# ----------------------------------------------------------------------
# OS VÍCIOS DO SEU EDITOR DE TEXTO (VSCode, RubyMine, etc)
# ----------------------------------------------------------------------
.vscode/
.idea/
*.swp
*~