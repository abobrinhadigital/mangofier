#!/usr/bin/env ruby
# bin/mangofier_analyzer
# "O Inspetor de Defuntos" do Pollux (PRECISION EDITION 🎯). 
# Verifica quais mangás estão há mais de 1 ano sem lançamentos REAIS.
# O mestre detectou que o last_updated dos metadados mente!

require_relative '../config/environment'

puts "🔥 A iniciar o Mangofier (Time Lord Edition)..."
# Helper para transformar tempo em algo que humanos (e Pollux) entendam
def tempo_legivel(segundos)
  return "0 dias" if segundos <= 0
  
  anos = segundos / (365 * 24 * 3600)
  segundos %= (365 * 24 * 3600)
  meses = segundos / (30 * 24 * 3600)
  segundos %= (30 * 24 * 3600)
  dias = segundos / (24 * 3600)
  
  partes = []
  partes << "#{anos}a" if anos > 0
  partes << "#{meses}m" if meses > 0
  partes << "#{dias}d" if dias > 0 || partes.empty?
  
  partes.join(" ")
end

begin
  mu = MangaUpdates.new
  modo_start = ARGV.include?("start")
  modo_abandon = ARGV.include?("abandon")
  modo_list = ARGV.include?("list")
  
  # Menu de Ajuda (O Mestre mandou ser organizado! 🏛️)
  if ARGV.empty?
    puts "🥭 --- MANGODIER ANALYZER : MENU DE COMANDOS ---"
    puts "Uso: ruby bin/mangofier_analyzer [COMANDO]"
    puts "\nComandos disponíveis:"
    puts "  start   - 📡 Varre a API do MangaUpdates para atualizar datas de lançamento (Lento/Online)"
    puts "  abandon - 🪓 Move obras inativas (+2 anos) para a lista 106 e remove localmente"
    puts "  list    - 📊 Exibe o relatório de status e links baseado nos dados do banco (Rápido/Offline)"
    puts "\nExemplo: ruby bin/mangofier_analyzer list"
    puts "-" * 50
    exit
  end
  
  # Pega os mangás do banco (Via MangaModel 🏛️)
  mangas = MangaModel.all_for_analysis
  
  if mangas.empty?
    puts "🕳️  Mestre, sua biblioteca local está vazia. Nada para analisar."
    exit
  end

  # --- MODO 1: START (A BUSCA LENTA NA API) ---
  if modo_start
    puts "📡 MODALIDADE START: Varrendo a API para atualizar as datas..."
    mangas.each_with_index do |manga, index|
      mu_id = manga['mu_id']
      titulo = manga['titulo']
      
      print "\r⏳ Analisando: #{index + 1}/#{mangas.length} - #{titulo.to_s[0..30]}... "
      $stdout.flush
      
      begin
        last_release_ts = mu.fetch_series_last_release_date(titulo, mu_id)
        if last_release_ts
          MangaModel.update_last_release(mu_id, last_release_ts)
        end
      rescue => e
        puts "\n🚨 Erro em #{titulo}: #{e.message}"
      end
      
      sleep(5) if index < mangas.length - 1
    end
    puts "\n✅ Análise concluída e banco atualizado!"
    exit
  end

  # --- MODO 2: ABANDON (O EXPURGO RÁPIDO VIA BANCO) ---
  if modo_abandon
    puts "🪓 MODALIDADE ABANDON: Movendo desertores há +2 anos..."
    
    mangas.each do |manga|
      mu_id = manga['mu_id']
      titulo = manga['titulo']
      last_ts = manga['last_release_at']
      
      is_abandoned = last_ts.nil? || (Time.now.to_i - last_ts) > (730 * 24 * 3600)
      
      if is_abandoned
        puts "💀 Expulsando '#{titulo}'..."
        if mu.add_to_list(mu_id, 106)
          sleep(5)
          if mu.remove_from_list(mu_id, 0)
            MangaModel.delete_by_mu_id(mu_id)
            puts "✅ '#{titulo}' movido para Abandonados e removido localmente."
            Pessegram.new.gritar("🪓 *Mangofier (Expurgo):* \"#{titulo}\" removido.")
            sleep(5)
          end
        else
          puts "🚨 Falha ao mover no MangaUpdates."
        end
      end
    end
    puts "🏁 Limpeza terminada."
    exit
  end

  # --- MODO 3: LIST (O RELATÓRIO DO MESTRE) ---
  if modo_list
    registros = []
    mangas.each do |manga|
      last_ts = manga['last_release_at']
      tempo = last_ts ? tempo_legivel(Time.now.to_i - last_ts) : "N/A"
      data = last_ts ? Time.at(last_ts).strftime("%d/%m/%Y") : "Nunca"
      
      link = if manga['custom_url'] && !manga['custom_url'].empty?
               manga['custom_url']
             elsif manga['md_id'] && !manga['md_id'].empty?
               "https://mangadex.org/title/#{manga['md_id']}"
             elsif manga['mp_url'] && !manga['mp_url'].empty?
               manga['mp_url']
             else
               "❌ Sem Link"
             end

      status = if last_ts.nil?
                 "❓ DESCONHECIDO"
               elsif (Time.now.to_i - last_ts) > (365 * 24 * 3600)
                 "💀 ABANDONADO"
               elsif (Time.now.to_i - last_ts) > (180 * 24 * 3600)
                 "⚠️ ALERTA"
               else
                 "✅ ATIVO"
               end

      registros << { 
        status: status, 
        mu_id: manga['mu_id'],
        id: manga['mu_id'].to_s(36), 
        titulo: manga['titulo'], 
        data: data, 
        tempo: tempo,
        link: link,
        segundos: last_ts ? (Time.now.to_i - last_ts) : 999999999
      }
    end

    registros.sort_by! { |r| r[:segundos] }.reverse!

    puts "\n📊 --- RELATÓRIO DE STATUS (DADOS DO BANCO) ---"
    puts "-" * 150
    puts "%-15s | %-10s | %-8s | %-30s | %-12s | %-10s | %-40s" % ["Status", "ID (num)", "ID (b36)", "Título", "Últ. Lançam.", "Inativo há", "Link de Leitura"]
    puts "-" * 150
    registros.each do |r|
      puts "%-15s | %-10s | %-8s | %-30s | %-12s | %-10s | %-40s" % [
        r[:status], r[:mu_id], r[:id], r[:titulo].to_s[0..29], r[:data], r[:tempo], r[:link].to_s[0..39]
      ]
    end
    puts "-" * 150
    exit
  end

  # Se chegou aqui com parâmetro inválido
  puts "🚨 Parâmetro desconhecido. Use 'ruby bin/mangofier_analyzer' para ver a ajuda."

rescue => e
  puts "\n🚨 Falha na execução: #{e.class} - #{e.message}"
end
