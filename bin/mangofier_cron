#!/usr/bin/env ruby
# bin/mangofier_cron

require_relative '../config/environment'
require_relative '../lib/manga_model'
require_relative '../lib/manga_updates'
require_relative '../lib/manga_dex'
require 'faraday'

puts "🔥 Iniciando o Mangofier (Otimizado Edition) no Abobrinator..."

def gritar_no_telegram(mensagem)
  token = ENV['TELEGRAM_BOT_TOKEN']
  chat_id = ENV['TELEGRAM_CHAT_ID']
  return puts "Erro: Cade o token do Telegram no .env?" unless token && chat_id

  Faraday.post("https://api.telegram.org/bot#{token}/sendMessage") do |req|
    req.body = { chat_id: chat_id, text: mensagem }.to_json
    req.headers['Content-Type'] = 'application/json'
  end
end

begin
  mu = MangaUpdates.new
  md = MangaDex.new

  # 1. Pega apenas os IDs da gaveta 0
  lista_de_ids = mu.fetch_reading_list
  
  # 2. Pede os lançamentos recentes de TODOS eles de uma vez só!
  lancamentos = mu.check_batch_releases(lista_de_ids)

  if lancamentos.empty?
    puts "💤 Nenhum lançamento novo. O i3 pode voltar a dormir."
    exit
  end

  # 3. Itera sobre a fofoca fresquinha
  lancamentos.each do |fofoca|
    mu_id = fofoca.dig(:series, :id)
    titulo = fofoca.dig(:series, :title) || "Mangá Desconhecido"
    ultimo_capitulo = fofoca[:chapter]

    next unless mu_id && ultimo_capitulo # Ignora se a API mandar lixo sem capítulo

    # Garante que a obra existe no nosso banco SQLite
    MangaModel.insert_manga(titulo, mu_id)
    db_manga = MangaModel.find_by_mu_id(mu_id)

    # A Preguiça: Se já avisamos desse capítulo, pula.
    next if db_manga['ultimo_capitulo_notificado'] == ultimo_capitulo.to_s

    # Monta a mensagem pro Pessegram
    mensagem = "🔥 Mestre, saiu o cap #{ultimo_capitulo} de #{titulo}!\n\n"
    
    if db_manga['md_id']
      cap_dex = md.get_latest_chapter_link(db_manga['md_id'], ['pt-br', 'en'])
      mensagem += cap_dex ? "📖 Leia (Dex): #{cap_dex[:url]}" : "MangaDex furou."
    elsif db_manga['mp_url']
      mensagem += "📖 Leia (Plus): #{db_manga['mp_url']}"
    elsif db_manga['custom_url']
      mensagem += "📖 Leia (Lixeira): #{db_manga['custom_url']}"
    else
      mensagem += "⚠️ Não sei onde o senhor lê isso. Responda com o link!\n[MU_ID: #{mu_id}]"
    end

    # Grita, salva no banco e respira
    gritar_no_telegram(mensagem)
    MangaModel.update_last_chapter(mu_id, ultimo_capitulo)
    puts "✅ Notificado: #{titulo} (Cap #{ultimo_capitulo})"
    sleep(2) # Pausa dramática pro Telegram não nos banir
  end
  
  puts "🏁 Fim da varredura. A paz reina no Proxmox."

rescue => e
  erro_msg = "🚨 Mestre, o Mangofier capotou no Proxmox:\n#{e.class}: #{e.message}"
  puts erro_msg
  gritar_no_telegram(erro_msg)
end