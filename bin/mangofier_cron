#!/usr/bin/env ruby
# bin/mangofier_cron

require_relative '../config/environment'
require_relative '../lib/manga_updates'

puts "🔥 A iniciar o Mangofier (Time Lord Edition)..."

begin
  mu = MangaUpdates.new
  pessegram = Pessegram.new

  last_check = SystemModel.get_last_check
  
  lancamentos, novo_last_check = mu.check_new_releases(last_check)

  if lancamentos.empty?
    puts "💤 Nenhum lançamento novo desde a última checagem."
    exit
  end

  lancamentos.each do |fofoca|
    mu_id = fofoca[:mu_id]
    titulo = fofoca[:titulo]
    ultimo_capitulo = fofoca[:capitulo]
    
    db_manga = MangaModel.find_by_mu_id(mu_id)
    
    next unless db_manga
    next if db_manga['ultimo_capitulo_notificado'] == ultimo_capitulo.to_s

    mensagem = "🔥 Mestre, saiu o cap #{ultimo_capitulo} de #{titulo}!\n\n"
    
    url_mu = "https://www.mangaupdates.com/series/#{mu_id.to_i.to_s(36)}"

    if db_manga['md_id']
      mensagem += "📖 Leia (Dex): https://mangadex.org/title/#{db_manga['md_id']}"
    elsif db_manga['mp_url']
      mensagem += "📖 Leia (Plus): #{db_manga['mp_url']}"
    elsif db_manga['custom_url']
      mensagem += "📖 Leia (Outros): #{db_manga['custom_url']}"
    else
      pagina_grupo = mu.fetch_group_site(mu_id)
      if pagina_grupo
        md_match = pagina_grupo.to_s.match(/mangadex\.org\/title\/([a-z0-9\-]+)/i)
        if md_match
          md_id = md_match[1]
          MangaModel.update_md_id(mu_id, md_id)
          mensagem += "📖 Leia (Grupo): https://mangadex.org/title/#{md_id}"
        else
          mensagem += "📖 Leia (Grupo): #{pagina_grupo}"
        end
      else
        mensagem += "⚠️ Não sei onde o senhor lê isto. Verifique o Scanlator nas informações."
      end
    end

    mensagem += "\n\nSe esta página estiver errada, por favor, responda esta mensagem com o link correto."

    mensagem += "\n\nℹ️ Veja informações da série no MU:\n#{url_mu}"

    pessegram.gritar(mensagem)
    
    MangaModel.update_last_chapter(mu_id, ultimo_capitulo)
    MangaModel.update_last_release(mu_id, fofoca[:timestamp])
    puts "✅ Processado: #{titulo} (Cap #{ultimo_capitulo})"
    sleep(2)
  end
  
  SystemModel.set_last_check(novo_last_check)
  puts "🏁 Fim da varredura. Novo Last Check salvo: #{novo_last_check}"

rescue => e
  erro_msg = "🚨 Mestre, o Mangofier capotou:\n#{e.class}: #{e.message}"
  puts erro_msg
  Pessegram.new.gritar(erro_msg) 
end