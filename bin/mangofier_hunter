#!/usr/bin/env ruby
# bin/mangofier_hunter
# Hype Hunter - O Caçador de Tendências do Pollux
# Analisa lançamentos da semana e descobre obras em ascensão

require_relative '../config/environment'

puts "🎯 --- HYPE HUNTER (O Caçador de Tendências) ---"
puts ""

begin
  # Garante que as tabelas necessárias existam
  MangaModel.ensure_hype_tracking_schema

  mu = MangaUpdates.new
  hunter = HypeHunter.new(mu)

  # Busca e analisa lançamentos da última semana
  ranked = hunter.fetch_and_analyze(1)

  if ranked.empty?
    puts "😴 Nenhum mangá hypado encontrado esta semana."
    exit 0
  end

  # Mostra relatório
  puts "\n" + hunter.format_report(ranked, 5)

  # Mostra top 10 detalhado
  puts "\n📊 --- TOP 10 MAIS HYPADOS ---"
  puts "-" * 100
  puts "%-4s | %-45s | %-8s | %-8s | %-8s | %-6s" % ["#", "Título", "Delta", "Antes", "Agora", "Rating"]
  puts "-" * 100

  ranked.first(10).each_with_index do |r, i|
    puts "%-4s | %-45s | %-8s | %-8s | %-8s | %-6s" % [
      i + 1,
      r[:title].to_s[0..44],
      "+#{r[:delta_week]}",
      "##{r[:rank_old]}",
      "##{r[:rank_current]}",
      r[:bayesian_rating]&.round(1)
    ]
  end
  puts "-" * 100

  puts "\n📊 Total analisado: #{ranked.length} séries únicas hypadas"

  # Marcar como hypeados (descomentar quando quiser ativar o anti-repetição)
  # hunter.mark_as_hyped(ranked.first(5))
  # puts "\n✅ Mangás notificados marcados como hypeados"

rescue => e
  puts "\n🚨 Falha no Hype Hunter: #{e.class} - #{e.message}"
  puts e.backtrace.first(5).join("\n") if ENV['DEBUG']
  exit 1
end
