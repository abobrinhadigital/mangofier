#!/usr/bin/env ruby
# bin/mangofier_migrate
# "O Arquiteto de Covas" do Pollux.
# Garante que o banco de dados tenha todas as colunas necessárias sem quebrar a estutura original.

require_relative '../config/environment'

puts "🧱 Pollux está reforçando as fundações do banco de dados..."

begin
  # Garante que o banco e as tabelas base existam
  SystemModel.db
  
  # Verifica se a coluna last_release_at já existe
  columns = DB.execute("PRAGMA table_info(mangas_mapeados)")
  exists = columns.any? { |col| col['name'] == 'last_release_at' }

  if exists
    puts "✅ A coluna 'last_release_at' já está presente. Nada a fazer."
  else
    puts "➕ Adicionando coluna 'last_release_at' à tabela 'mangas_mapeados'..."
    DB.execute("ALTER TABLE mangas_mapeados ADD COLUMN last_release_at INTEGER")
    puts "🚀 Migração concluída com sucesso!"
  end

rescue => e
  puts "🚨 Erro catastrófico na migração: #{e.message}"
  exit 1
end
