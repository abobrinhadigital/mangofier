#!/usr/bin/env ruby
require_relative '../config/environment'

# Helper para transformar tempo em algo que humanos (e Pollux) entendam
def tempo_legivel(segundos)
  return "N/A" if segundos.nil? || segundos <= 0
  
  agora = Time.now.to_i
  diff = agora - segundos
  return "Recente" if diff < 0
  
  anos = diff / (365 * 24 * 3600)
  diff %= (365 * 24 * 3600)
  meses = diff / (30 * 24 * 3600)
  diff %= (30 * 24 * 3600)
  dias = diff / (24 * 3600)
  
  partes = []
  partes << "#{anos}a" if anos > 0
  partes << "#{meses}m" if meses > 0
  partes << "#{dias}d" if dias > 0 || partes.empty?
  
  partes.join(" ")
end

puts "📊 --- STATUS DA BIBLIOTECA DO MESTRE ---"
puts "%-25s | %-12s | %-10s | %-s" % ["Título", "Últ. Lançam.", "Inativo", "Caminho / Link"]
puts "-" * 120

MangaModel.all_for_analysis.each do |manga|
  data_bruta = manga['last_release_at']
  data_formatada = data_bruta ? Time.at(data_bruta).strftime("%d/%m/%Y") : "---"
  inatividade = tempo_legivel(data_bruta)
  
  # Prioriza URLs para mostrar onde o mestre lê
  link = manga['custom_url'] || manga['mp_url'] || manga['md_id'] || "❌"
  
  puts "%-25s | %-12s | %-10s | %-s" % [
    manga['titulo'].to_s[0..24], 
    data_formatada,
    inatividade,
    link.to_s[0..60]
  ]
end
puts "-" * 120
