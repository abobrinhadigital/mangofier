#!/usr/bin/env ruby
# bin/mangofier_status
# Cockpit de Saúde do Mangofier - Pollux (v2.0)

require_relative '../config/environment'

# --- Helpers ---
def status_label(check)
  check ? "✅ OK" : "🚨 FALHA"
end

def tempo_legivel(timestamp)
  return "Nunca" if timestamp.nil? || timestamp <= 0
  agora = Time.now.to_i
  diff = agora - timestamp
  
  return "Recente" if diff < 60
  
  minutos = diff / 60
  horas = minutos / 60
  dias = horas / 24
  
  return "#{dias}d" if dias > 0
  return "#{horas}h" if horas > 0
  "#{minutos}m"
end

# --- 1. Checagem de Infraestrutura (Systemd) ---
# Sem sudo, pois o mestre reina como root
service_status = `systemctl is-active mangofier.service`.strip rescue "unknown"
service_ok = (service_status == "active")

# --- 2. Checagem de Processo (Ruby) ---
# Busca o serviço ou o listener (ps aux é o feijão com arroz universal)
process_check = `ps aux | grep -E "mangofier_service|api_listener" | grep -v grep`.strip rescue ""
process_ok = !process_check.empty?

# --- 3. Checagem de Persistência (Banco) ---
# Usando o método oficial do Modelo como o mestre exige!
db_ok = MangaModel.health_check?

# --- 4. Checagem de Sincronização (Cron/Sync) ---
last_sync = SystemModel.get_last_check
sync_ok = (Time.now.to_i - last_sync) < (25 * 3600) # Reclama se passar de 25h

puts "🏛️  --- MANGOLIER COCKPIT : SAÚDE DO SISTEMA ---"
puts "------------------------------------------------"
puts "📦 SERVIÇO (Systemd) : [%-8s] (%s)" % [status_label(service_ok), service_status]
puts "🎧 LISTENER (API)     : [%-8s] (Processo Ativo)" % [status_label(process_ok)]
puts "🗄️  BANCO DE DADOS     : [%-8s] (SQLite Mangofier)" % [status_label(db_ok)]
puts "🔄 SINCRONIZAÇÃO     : [%-8s] (Última: #{Time.at(last_sync).strftime('%d/%m %H:%M')} - Há #{tempo_legivel(last_sync)})" % [status_label(sync_ok)]
puts "------------------------------------------------"

# --- 5. Resumo da Biblioteca ---
mangas = MangaModel.all_for_analysis
total = mangas.length
ativos = mangas.count { |m| m['last_release_at'] && (Time.now.to_i - m['last_release_at']) < (180 * 24 * 3600) }
abandonados = total - ativos

puts "\n📊 RESUMO DA BIBLIOTECA"
puts "Total de Obras: #{total}"
puts "Obras Ativas  : #{ativos}"
puts "Em Hiato/Aband: #{abandonados}"
puts "------------------------------------------------"

# Se o mestre quiser detalhes, ele usa o analyzer list
puts "💡 Dica: Use 'ruby bin/mangofier_analyzer list' para o relatório detalhado."
puts "Pollux encerrou o diagnóstico. Murphy foi avistado fugindo."
