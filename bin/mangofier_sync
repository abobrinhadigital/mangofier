#!/usr/bin/env ruby
# bin/mangofier_sync

require_relative '../config/environment'

puts "🔄 Iniciando Sincronização Diária da Reading List..."

begin
  mu = MangaUpdates.new
  
  # 1. Busca a lista completa com metadata (inclui latest_chapter)
  lista_api = mu.fetch_reading_list_with_metadata
  ids_na_api = lista_api.map { |item| item[:mu_id] }

  # 2. Pega o que temos no banco atualmente
  ids_no_banco = MangaModel.get_all_mu_ids

  # 3. Inserir os novos e atualizar latest_chapter
  lista_api.each do |item|
    mu_id = item[:mu_id]
    titulo = item[:titulo]
    latest_chapter = item[:latest_chapter]
    
    MangaModel.insert_manga(titulo, mu_id)
    
    # Atualiza o último capítulo se disponível
    if latest_chapter
      db_manga = MangaModel.find_by_mu_id(mu_id)
      cap_atual = db_manga['ultimo_capitulo_notificado']
      
      if cap_atual != latest_chapter.to_s
        puts "📝 #{titulo}: cap #{cap_atual || 'N/A'} → #{latest_chapter}"
        MangaModel.update_last_chapter(mu_id, latest_chapter)
      end
    end
  end

  # 4. A mágica da limpeza: O que tem no banco MAS NÃO TEM na API?
  ids_para_remover = ids_no_banco - ids_na_api
  
  ids_para_remover.each do |id_removido|
    MangaModel.delete_by_mu_id(id_removido)
    puts "🗑️ Mangá removido do banco (MU_ID: #{id_removido})"
  end

  puts "✅ Sync Completo!"
  puts "📊 Total na API: #{ids_na_api.length}"
  puts "📊 Total no Banco: #{MangaModel.get_all_mu_ids.length}"
  puts "🧹 Removidos nesta rodada: #{ids_para_remover.length}"

rescue => e
  puts "🚨 Falha na sincronização: #{e.class} - #{e.message}"
end